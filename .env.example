# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (server default model)
OPENROUTER_API_KEY=

# Firecrawl (URL ingestion)
FIRECRAWL_API_KEY=

# Cron protection
CRON_SECRET=

# Upstash Redis (production rate limits — optional; falls back to in-memory locally)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limits (optional overrides)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_SECONDS=3600

# PostHog — ragbase project (Project Settings → Project API key, starts with phc_)
# Do NOT use a personal API key (phx_*) for event capture.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App URL (recovery links, Stripe return URLs)
NEXT_PUBLIC_APP_URL=https://www.ragbase.dev
# Display-only copy for upgrade CTAs — quote values that start with $
NEXT_PUBLIC_PRO_PRICE_DISPLAY="$9 a month"
# Stripe (phase 6c)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOKS_ENABLED=false
STRIPE_PRO_PRODUCT_ID=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_BILLING_ENABLED=false
# Required for Checkout Sessions API (preferred over Payment Links)
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_URL=
NEXT_PUBLIC_STRIPE_SUCCESS_URL=
NEXT_PUBLIC_STRIPE_CANCEL_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=support@ragbase.dev
RECOVERY_TOKEN_PEPPER=

# Crawl limits (Pro — phase 6d)
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=25
CRAWL_MAX_ACTIVE_PER_WORKSPACE=1
CRAWL_MAX_CRAWLS_PER_PERIOD=3
CRAWL_MAX_PAGES_PER_PERIOD=75
